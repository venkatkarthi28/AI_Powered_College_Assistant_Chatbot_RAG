# ══════════════════════════════════════════════════════════
# .env — Environment Configuration
# ══════════════════════════════════════════════════════════
#
# HOW TO USE:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your Gemini API key below
#   3. The app reads this file at startup
#
# ══════════════════════════════════════════════════════════

# ── REQUIRED: Gemini API Key ──────────────────────────
# Get your free API key from: https://makersuite.google.com/app/apikey
# Paste it below (remove the angle brackets)
GEMINI_API_KEY=AIzaSyATkkQkk9G-erUJRanoEnu392tZ4cXXYNI
# ── OPTIONAL: Change the local LLM model ─────────────
# Default: TinyLlama (600MB, fast, CPU-friendly)
# Alternatives:
#   mistralai/Mistral-7B-Instruct-v0.2  (needs 8GB RAM)
#   TheBloke/Llama-2-7B-Chat-GGUF       (needs llama-cpp-python)
LOCAL_MODEL_NAME=TinyLlama/TinyLlama-1.1B-Chat-v1.0

# ── OPTIONAL: Flask Settings ─────────────────────────
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
